    <style name="OwlyButton.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/btn_outline_text</item>
        <item name="strokeColor">@color/btn_outline_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
    <style name="OwlyButton.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/accent_primary</item>
        <item name="android:textColor">@color/accent_primary_text</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
    <style name="OwlyCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>
    <style name="OwlyDialog" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/OwlyButton.Primary</item>
        <item name="buttonBarNegativeButtonStyle">@style/OwlyButton.Outline</item>
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
    </style>
    <style name="OwlyTextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="boxStrokeColor">@color/input_stroke</item>
        <item name="boxBackgroundColor">@color/input_bg</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>
    <style name="OwlyTextInput.Dense" parent="OwlyTextInput">
        <item name="android:minHeight">48dp</item>
    </style>
    <style name="Theme.Owly" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryVariant">@color/accent_primary</item>
        <item name="colorOnPrimary">@color/accent_primary_text</item>
        <item name="colorSecondary">@color/accent_primary</item>
        <item name="colorOnSecondary">@color/accent_primary_text</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/header_bg</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="Theme.Owly.Splash" parent="Theme.Owly">
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>
